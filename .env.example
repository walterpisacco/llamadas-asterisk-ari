ARI_BASE_URL=http://127.0.0.1:8088
ARI_USER=admin
ARI_PASSWORD=change_me
STASIS_APP=StasisApp
OUTBOUND_ENDPOINT_TEMPLATE=PJSIP/{number}
OUTBOUND_CONTEXT=SuperAdmin
OUTBOUND_EXTENSION=1100
OUTBOUND_CALLER_ID=IA Bot <1000>
# Operador por teléfono (opcional si usás WebRTC en el navegador)
# AGENT_ENDPOINT=PJSIP/1000
# Si no se define, el frontend registra la extensión del operador al iniciar
AGENT_ENDPOINT_TEMPLATE=PJSIP/{extension}
# WebRTC + externalMedia (audio del panel en el navegador)
WEBRTC_ENABLED=true
# IP que Asterisk usa para enviar RTP al backend (no 127.0.0.1 si Asterisk es remoto)
EXTERNAL_MEDIA_ADVERTISE_HOST=127.0.0.1
EXTERNAL_MEDIA_FORMAT=ulaw
WEBRTC_STUN_URL=stun:stun.l.google.com:19302
CORS_ORIGINS=http://localhost:5173
HOST=0.0.0.0
PORT=8000
# Recarga la API al guardar .py (arrancar con: python main.py)
DEV_RELOAD=false
# Depuración de audio/ARI (logs + GET /api/debug/*)
ARI_DEBUG=false
ARI_DEBUG_FULL_EVENTS=false
# Si true, reproduce sound:hello-world al contestar saliente (prueba RTP)
ARI_DEBUG_PLAY_SOUND=false
